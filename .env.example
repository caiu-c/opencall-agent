# opencall-agent configuration. Copy to `.env` and adjust as needed.
# All keys use the OPENCALL_ prefix. Defaults in src/opencall_agent/config.py.

# --- Services ---
OPENCALL_OLLAMA_BASE_URL=http://localhost:11434
OPENCALL_QDRANT_URL=http://localhost:6333

# --- Models (LiteLLM-style "provider/model") ---
OPENCALL_LLM_MODEL=ollama/qwen2.5:7b
OPENCALL_EMBED_MODEL=ollama/nomic-embed-text

# --- Generation / retrieval tuning ---
OPENCALL_LLM_TEMPERATURE=0.0
OPENCALL_RETRIEVAL_TOP_K=5
OPENCALL_RETRIEVAL_SCORE_THRESHOLD=0.5
